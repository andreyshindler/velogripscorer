# Copy to .env and edit before `docker compose up`.

# REQUIRED: random secret for signing login tokens. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=

# REQUIRED: password for the seeded administrator account.
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@velogripscorer.local

# OPTIONAL: your hostname for automatic HTTPS (needs DNS pointing at this VPS).
# Leave empty to serve plain HTTP on port 80.
DOMAIN=

# OPTIONAL: serve the app under a URL prefix instead of the domain root,
# e.g. BASE_PATH=/veloscorer -> https://your-host/veloscorer
BASE_PATH=

# OPTIONAL: host port the container publishes on 127.0.0.1 (default 3000).
# Only needed to run a second (staging) stack next to prod, e.g. HOST_PORT=3001.
HOST_PORT=

# OPTIONAL: reader WiFi the timing app should join. The SSID defaults to
# Tenda_raceit; the password is handed to logged-in organizers so the app can
# pre-fill and connect to the reader network for them.
READER_WIFI_SSID=Tenda_raceit
READER_WIFI_PASSWORD=

# OPTIONAL: Telegram start-list bot. Set a bot token (from @BotFather) to enable
# managing a race's start list from Telegram — add / edit / delete racers and
# pull the results CSV. The bot acts as the admin account.
TELEGRAM_BOT_TOKEN=
# REQUIRED when the bot is enabled: comma-separated Telegram numeric user ids
# allowed to use it. The bot ignores everyone else (and everyone if this is
# empty). Message the running bot /whoami to learn your id, then set it here.
TELEGRAM_ALLOWED_USER_IDS=
# OPTIONAL: a second bot (from @BotFather) that serves ONLY the runner
# self-service flow — regular users DM it to submit a bib and view their
# ranking/team once approved. Approvals still happen on the operator bot above,
# so one person can test both roles (DM the runner bot; approve on the operator
# bot). Leave empty to keep it off. Must be a DIFFERENT bot than the operator.
TELEGRAM_RUNNER_BOT_TOKEN=
# Optional public site URL. When set, the day-before race reminder the bot sends
# includes a link to the race results page, e.g. https://host/veloscorer
PUBLIC_BASE_URL=
