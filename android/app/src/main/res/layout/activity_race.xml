<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/raceHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/race_title"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/downloadStartList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/download_startlist" />

        <Button
            android:id="@+id/uploadRace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/upload_race" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/readerStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_idle"
            android:textSize="14sp" />

        <Button
            android:id="@+id/connectReader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/connect_reader" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/wavesBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/newWaveName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/wave_name_hint"
            android:inputType="text" />

        <Button
            android:id="@+id/addWave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_wave" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/manualBib"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/manual_bib_hint"
            android:inputType="textVisiblePassword" />

        <Button
            android:id="@+id/recordManual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/record_manual" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/standings"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/resultsView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#111827"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:textColor="#D5E0FF"
            android:textSize="13sp" />
    </ScrollView>
</LinearLayout>
