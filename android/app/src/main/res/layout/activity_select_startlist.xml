<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <include layout="@layout/header_flow" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rowDownloadWeb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="18dp"
                android:paddingVertical="22dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="⬇️"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/downloadWebLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chevron"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="❯"
                    android:textColor="@color/velogrip_green"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/menu_divider" />

            <LinearLayout
                android:id="@+id/rowFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="18dp"
                android:paddingVertical="22dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="📄"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/option_file"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chevron"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="❯"
                    android:textColor="@color/velogrip_green"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/menu_divider" />
        </LinearLayout>
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/menu_section_bg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="@string/choose_setup_option"
        android:textColor="#333333"
        android:textSize="15sp" />

    <include layout="@layout/bottom_bar" />
</LinearLayout>
